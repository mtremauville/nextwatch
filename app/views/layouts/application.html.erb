<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>WatchNext</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body>
  <nav class="navbar">
    <a href="<%= root_path %>" class="navbar__brand">
      <span class="navbar__logo">▶</span>
      <span class="navbar__name">WATCHNEXT</span>
    </a>
    <div class="navbar__links">
      <% if user_signed_in? %>
        <%= link_to "Dashboard", root_path, class: "nav-link" %>
        <%= link_to "Ma liste", watch_items_path, class: "nav-link" %>
        <%= link_to "Rotations", rotations_path, class: "nav-link" %>
        <%= link_to "Recommandations", recommendations_path, class: "nav-link" %>
        <div class="navbar__sep"></div>
        <%= link_to current_user.email.split("@").first, "#", class: "nav-user" %>
        <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "nav-signout" %>
      <% else %>
        <%= link_to "Connexion", new_user_session_path, class: "btn-primary" %>
      <% end %>
    </div>
  </nav>

  <% if notice %>
    <div class="flash flash--notice" data-controller="flash"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="flash flash--alert" data-controller="flash"><%= alert %></div>
  <% end %>

  <main class="main-content">
    <%= yield %>
  </main>
  <%= yield :coverflow %>

  <div id="modal-container"
       data-controller="modal"
       data-action="turbo:frame-load@window->modal#openIfModal click->modal#closeOnBackdrop"
       hidden>
    <turbo-frame id="modal" data-modal-target="frame"></turbo-frame>
  </div>
</body>
</html>
